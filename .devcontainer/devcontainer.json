{
  "name": "gadk-sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "GOOGLE_ADK_VERSION": "1.31.1",
      "CODEX_CLI_VERSION": "latest",
      "FIRECRAWL_CLI_VERSION": "1.19.6",
      "TTYD_VERSION": "1.7.7"
    }
  },
  "containerEnv": {
    "GADK_VENV": "/opt/gadk-venv",
    "CODEX_HOME": "/root/.codex"
  },
  "remoteEnv": {
    "PATH": "/opt/gadk-venv/bin:${containerEnv:PATH}",
    "GOOGLE_API_KEY": "${localEnv:GOOGLE_API_KEY}",
    "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "FIRECRAWL_API_KEY": "${localEnv:FIRECRAWL_API_KEY}"
  },
  "forwardPorts": [
    7681
  ],
  "mounts": [
    {
      "source": "gadk-sandbox-codex-home",
      "target": "/root/.codex",
      "type": "volume"
    }
  ],
  "portsAttributes": {
    "7681": {
      "label": "Browser terminal",
      "onAutoForward": "notify",
      "visibility": "private"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/gadk-venv/bin/python",
        "python-envs.defaultEnvManager": "ms-python.python:venv",
        "python-envs.defaultPackageManager": "ms-python.python:pip",
        "python-envs.pythonProjects": [
          {
            "path": ".",
            "envManager": "ms-python.python:venv",
            "packageManager": "ms-python.python:pip"
          }
        ]
      }
    }
  },
  "postCreateCommand": "python --version && adk --version && codex --version && firecrawl --version",
  "postStartCommand": "firecrawl-skills-from-cli && codex-login-from-env && (pgrep -f 'ttyd .*7681' >/dev/null || nohup start-browser-terminal >/tmp/browser-terminal.log 2>&1 &)"
}
